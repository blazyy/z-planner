{
  "root": true,
  // prettier last so eslint-config-prettier disables formatting rules that fight Prettier (task 1).
  "extends": ["next/core-web-vitals", "plugin:jsx-a11y/recommended", "prettier"],
  "plugins": ["import"],
  "rules": {
    "import/order": [
      "error",
      {
        "groups": ["builtin", "external", "internal", ["parent", "sibling", "index"]],
        "newlines-between": "always",
        "alphabetize": { "order": "asc", "caseInsensitive": true }
      }
    ],
    // Click handlers live on divs nested INSIDE Radix interactive primitives (ContextMenuItem,
    // CommandItem) that already supply keyboard/focus semantics; the inner div only carries the
    // Radix render props + onClick. Adding our own key handlers/roles would be redundant and would
    // change runtime behavior, which this lane forbids. Disabled as inapplicable to the Radix pattern.
    "jsx-a11y/click-events-have-key-events": "off",
    "jsx-a11y/no-static-element-interactions": "off",
    // forwardRef shadcn heading primitives (CardTitle, AlertTitle) render <h3 {...props}/>; their
    // content arrives via children at the call site, which the rule cannot see statically. False positive.
    "jsx-a11y/heading-has-content": "off"
  },
  "overrides": [
    {
      // Vitest test setup interleaves vi.hoisted/vi.mock between imports by design (the SUT import
      // must follow its mock registration). import/order's "no intervening statements" assumption
      // doesn't hold for this idiom, so it's off for test files only.
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": { "import/order": "off" }
    }
  ]
}
